# Copy to .env for local dev. Real values live in Vercel's Environment
# Variables settings for deployed environments — never commit .env.
#
# Point these at the free-tier Neon/Upstash instances described in
# README.md; there is no local Docker/Postgres/Redis to run (§3 of the
# build brief — this is a Vercel-native serverless stack).

NODE_ENV=development

# Neon (https://neon.tech) — free tier Postgres. Create a project, copy the
# pooled connection string.
DATABASE_URL=postgresql://user:password@ep-example-000000.region.aws.neon.tech/netverdict?sslmode=require

# Upstash Redis (https://upstash.com) — free tier. Create a database, copy
# the REST credentials (not the raw redis:// URL — the REST API is what
# makes this usable from Vercel's serverless functions).
UPSTASH_REDIS_REST_URL=https://example-000000.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Auth.js (Phase 4). Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
